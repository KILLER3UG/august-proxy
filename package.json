{
  "name": "august-proxy",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend/desktop",
    "frontend/mobile"
  ],
  "scripts": {
    "start": "node backend/index.js",
    "launch": "node backend/launch.js",
    "dev": "node scripts/dev-app.mjs",
    "dev:web": "npm run dev:vite -w frontend/desktop",
    "memory:eval": "node backend/scripts/run-memory-eval.js",
    "build:web": "npm run build -w frontend/desktop",
    "preview:web": "npm run preview -w frontend/desktop",
    "download:node-binaries": "node scripts/download-node-binaries.mjs",
    "download:node-binaries:all": "node scripts/download-node-binaries.mjs --all",
    "release:patch": "node scripts/release-desktop.mjs patch",
    "release:minor": "node scripts/release-desktop.mjs minor",
    "release:desktop": "npm run build:web && npm run download:node-binaries && npm run tauri -w frontend/desktop build",
    "test:backend": "node --test backend/test/verification.test.js backend/test/sse-streaming.test.cjs backend/test/route-resolver.test.cjs backend/test/model-resolver.test.cjs backend/test/session-model-inheritance.test.cjs backend/test/sub-agent-alias.test.cjs backend/test/scheduler.test.js",
    "test:memory": "node --test backend/test/memory-evals.test.cjs backend/test/memory-quality.test.cjs backend/test/memory-service-tools.test.cjs",
    "test:frontend": "npm run test -w frontend/desktop",
    "test:verify": "npm run test:backend && npm run test:memory && npm run test:frontend",
    "test": "npm run test:verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-pty": "^1.1.0",
    "turndown": "^7.2.4",
    "zod": "^3.25.76"
  }
}
