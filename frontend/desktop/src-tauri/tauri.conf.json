{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "August",
  "version": "0.12.2",
  "identifier": "com.august.proxy",
  "build": {
    "frontendDist": "../../../web-dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "August",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "resources": [
      "binaries/*",
      "resources/**/*"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local AI proxy and chat",
    "longDescription": "August Proxy — local AI gateway, chat, and provider routing."
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFRjVGM0E1RTlDMkUzNTAKUldSUTQ4THBwZlAxWHFoMTRFVXUvNldiaC9vTGVHRFlNdGxXZkpSZk5zN3Y4ckY1VkFidlp5ZDEK",
      "endpoints": [
        "https://github.com/KILLER3UG/august-proxy/releases/latest/download/latest.json"
      ]
    }
  }
}
