# ── August Proxy — API Keys Template ─────────────────────────────────
# Copy this file to .env and fill in your actual keys
# Keep .env out of git: it is already in .gitignore
# ────────────────────────────────────────────────────────────────────────

# MiniMax (used by claude profile + bookmarks)
MINIMAX_API_KEY=your-minimax-api-key-here

# NVIDIA NIM (used by codex profile + NVIDIA bookmark)
NVIDIA_API_KEY=your-nvidia-api-key-here

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Kilocode
KILOCODE_API_KEY=your-kilocode-api-key-here

# Opencode (original /zen/v1 endpoint)
OPENCODE_API_KEY=your-opencode-api-key-here

# Opencode GO (/zen/go/v1 endpoint)
OPENCODE_GO_API_KEY=your-opencode-go-api-key-here

# Cline
CLINE_API_KEY=your-cline-api-key-here

# August Core Security Gateway (for external access to the proxy)
GATEWAY_API_KEY=your-personal-key-here

# Google Workspace OAuth for Services (Gmail, Calendar, Drive, Docs, Sheets)
# Loaded into process env at startup (see backend-py/app/config.py).
#
# Recommended: Google Cloud → OAuth client type **Desktop app**
# - Client ID only (PKCE) — leave SECRET empty for one-click Sign in
# - Or Web client + SECRET if you prefer confidential clients
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=  # optional for Desktop + PKCE
# Must EXACTLY match an Authorized redirect URI on that OAuth client:
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8085/api/service-connections/google/callback
# Allow http:// loopback redirects during local development
OAUTHLIB_INSECURE_TRANSPORT=1
# Optional: ship-time public Desktop client id for true one-click (no user paste).
# Never put a client secret here for public open-source builds.
# Optional ship-time public Desktop OAuth client ID (PKCE, no secret in git).
# When set, users see "Sign in with Google" without pasting a Client ID first.
# Create your own Desktop app in Google Cloud Console for production releases.
# AUGUST_DEFAULT_GOOGLE_OAUTH_CLIENT_ID=

# Desktop/local app workspace roots. Semicolon-separated.
# Example:
# AUGUST_PROXY_ALLOWED_ROOTS=C:\Dev\Hermes\hermes-agent;C:\Dev\opencode
# AUGUST_PROXY_WORKDIR=C:\Dev\Hermes\hermes-agent
# AUGUST_PROXY_CONTAINER_ROOT=/app
