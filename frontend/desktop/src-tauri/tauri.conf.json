{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "August",
  "version": "0.1.0",
  "identifier": "com.august.proxy",
  "build": {
    "frontendDist": "../../web-dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "August",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": ["binaries/*"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local AI proxy and chat",
    "longDescription": "August Proxy — local AI gateway, chat, and provider routing."
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFNUYwNzg2QTg2MUVFNkYKUldSdjdtR29oZ2RmWHNIbGxVcGRHS0EvbTRMTzRmT3dZMkNrWW9NRUNIQVgvRXRGaDQvWDl5eFUK",
      "endpoints": [
        "https://github.com/KILLER3UG/august-proxy/releases/latest/download/latest.json"
      ]
    }
  }
}
